default_platform(:ios)

KEY_ID       = "3349GWYVGR"
ISSUER_ID    = "220f0894-51a2-449c-ad61-9715441b4a11"
TEAM_ID      = "3LN6SHFTXK"
BUNDLE_ID    = "john.Boxing-Timer"

def api_key
  key_path = File.expand_path(ENV["ASC_KEY_FILEPATH"] || "~/Desktop/appstuff/keys/apple-keys/AuthKey_#{KEY_ID}.p8")
  app_store_connect_api_key(
    key_id: KEY_ID,
    issuer_id: ISSUER_ID,
    key_filepath: key_path,
    duration: 1200,
    in_house: false
  )
end

# xcodebuild auth flags — lets Xcode auto-download dist cert + provisioning profile
def xcode_auth_xcargs
  key_path = File.expand_path(ENV["ASC_KEY_FILEPATH"] || "~/Desktop/appstuff/keys/apple-keys/AuthKey_#{KEY_ID}.p8")
  "-allowProvisioningUpdates " \
  "-authenticationKeyPath #{key_path} " \
  "-authenticationKeyID #{KEY_ID} " \
  "-authenticationKeyIssuerID #{ISSUER_ID}"
end

platform :ios do

  # ── beta: build + upload to TestFlight ─────────────────────────────────────
  desc "Build and upload a new build to TestFlight"
  lane :beta do
    key = api_key

    increment_build_number(xcodeproj: "Boxing Timer.xcodeproj")

    gym(
      project: "Boxing Timer.xcodeproj",
      scheme: "Boxing Timer",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "BoxingTimer",
      clean: true,
      xcargs: xcode_auth_xcargs
    )

    upload_to_testflight(
      api_key: key,
      skip_waiting_for_build_processing: true
    )
  end

  # ── release: build + submit to App Store ───────────────────────────────────
  desc "Build and submit a new version to the App Store"
  lane :release do
    key = api_key

    increment_build_number(xcodeproj: "Boxing Timer.xcodeproj")

    gym(
      project: "Boxing Timer.xcodeproj",
      scheme: "Boxing Timer",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "BoxingTimer",
      clean: true,
      xcargs: xcode_auth_xcargs
    )

    upload_to_app_store(
      api_key: key,
      submit_for_review: true,
      automatic_release: true,
      force: true,
      skip_screenshots: true,
      skip_metadata: false,
      precheck_include_in_app_purchases: false
    )
  end

  # ── upload: upload a pre-built .ipa to App Store Connect ──────────────────
  desc "Upload a pre-built IPA to App Store (skips build step)"
  lane :upload do |options|
    key = api_key
    ipa_path = options[:ipa] || "./build/BoxingTimer.ipa"

    upload_to_app_store(
      api_key: key,
      ipa: ipa_path,
      submit_for_review: false,
      automatic_release: false,
      force: true,
      skip_screenshots: true,
      skip_metadata: true,
      precheck_include_in_app_purchases: false
    )
  end

  # ── screenshots: capture App Store screenshots ─────────────────────────────
  # Uses simctl io screenshot triggered by NSLog "snapshot: <name>" parsing,
  # bypassing fastlane's broken OS version matching for iOS 26.x simulators.
  desc "Capture App Store screenshots via snapshot"
  lane :screenshots do
    # Device UDIDs — update if simulators are recreated
    devices = {
      "iPhone 17 Pro Max" => "F2310914-3385-4C5A-8C0E-F990FFDAE113",
      "iPhone 17 Pro"     => "58539C49-E5C1-4566-9215-1CE33ACEB315",
      "iPhone 16e"        => "50F52ACB-529F-4D1F-A749-5D50790F72B4"
    }

    # Fastfile lives in ios/fastlane/, so ".." = ios/ directory
    ios_dir    = File.expand_path("..")
    output_dir = "#{ios_dir}/fastlane/screenshots/en-US"
    FileUtils.rm_rf(output_dir)
    FileUtils.mkdir_p(output_dir)

    project_dir = ios_dir
    derived    = "/tmp/snapshot_direct_#{Time.now.to_i}"

    devices.each do |device_name, udid|
      UI.message("Capturing screenshots on #{device_name} (#{udid})...")

      # Script that runs xcodebuild and captures screenshots from simctl on each "snapshot: <name>" line
      capture_script = <<~BASH
        set -e
        # Boot simulator if needed
        xcrun simctl boot #{udid} 2>/dev/null || true

        # Override status bar for clean screenshots
        xcrun simctl status_bar #{udid} override \
          --time 09:41 --dataNetwork wifi --wifiMode active --wifiBars 3 \
          --cellularMode active --operatorName '' --cellularBars 4 \
          --batteryState charged --batteryLevel 100 2>/dev/null || true

        # Run tests and watch for snapshot: <name> log lines
        xcodebuild \
          -scheme 'Boxing TimerUITests' \
          -project '#{project_dir}/Boxing Timer.xcodeproj' \
          -derivedDataPath '#{derived}' \
          -destination 'platform=iOS Simulator,id=#{udid}' \
          FASTLANE_SNAPSHOT=YES FASTLANE_LANGUAGE=en-US \
          build test 2>&1 | while IFS= read -r line; do
            echo "$line"
            if [[ "$line" =~ "snapshot: "(.+)$ ]]; then
              name="${BASH_REMATCH[1]}"
              # Trim whitespace and carriage returns
              name=$(echo "$name" | tr -d '\\r' | xargs)
              outfile="#{output_dir}/#{device_name}-${name}.png"
              xcrun simctl io #{udid} screenshot "$outfile" && echo "Saved: $outfile" || true
            fi
          done
      BASH

      sh(capture_script)
    end

    count = Dir.glob("#{output_dir}/*.png").count
    UI.success("Done! #{count} screenshots saved to fastlane/screenshots/en-US/")
  end

  # ── codesign: create/download distribution cert + provisioning profile ──────
  desc "Create Apple Distribution certificate and App Store provisioning profile"
  lane :codesign do
    key = api_key

    get_certificates(
      api_key: key,
      output_path: "./certs"
    )

    get_provisioning_profile(
      api_key: key,
      app_identifier: BUNDLE_ID,
      output_path: "./certs"
    )
  end

end
